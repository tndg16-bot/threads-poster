            },
            {
              "name": "access_token",
              "value": "={{ $credentials.httpCustomAuth.token }}"
            }
          ]
        },
        "options": {}
      },
      "id": "create-reply-container",
      "name": "リプライコンテナ作成",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2880, 100],
      "credentials": {
        "httpCustomAuth": {
          "id": "PLACEHOLDER_THREADS_TOKEN_CREDENTIAL_ID",
          "name": "Threads Access Token"
        }
      },
      "onError": "continueErrorOutput",
      "notes": "Threads API Step3: セルフリプライで記事URLを投稿"
    },
    {
      "parameters": {
        "amount": 5,
        "unit": "seconds"
      },
      "id": "wait-reply-container",
      "name": "リプライコンテナ待ち (5秒)",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [3120, 100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.threads.net/v1.0/me/threads_publish",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpCustomAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "creation_id",
              "value": "={{ $json.id }}"
            },
            {
              "name": "access_token",
              "value": "={{ $credentials.httpCustomAuth.token }}"
            }
          ]
        },
        "options": {}
      },
      "id": "publish-reply",
      "name": "リプライ公開",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3360, 100],
      "credentials": {
        "httpCustomAuth": {
          "id": "PLACEHOLDER_THREADS_TOKEN_CREDENTIAL_ID",
          "name": "Threads Access Token"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "// Merge back: both reply path and no-reply path converge here\nconst item = $input.item;\nconst publishedId = item.json._publishedId || item.json.id || 'unknown';\n\nreturn {\n  json: {\n    _publishedId: publishedId,\n    _status: '投稿済み',\n    _rowNumber: item.json._rowNumber || 0,\n    _fullText: item.json._fullText || '',\n    _category: item.json['カテゴリ'] || item.json['D'] || '',\n    _articleUrl: item.json._articleUrl || ''\n  }\n};"
      },
      "id": "merge-success",
      "name": "成功データ統合",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3600, 200]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "mode": "list",
          "value": ""
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "投稿スケジュール"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "H": "={{ $json._status }}",
            "I": "={{ $json._publishedId }}"
          },
          "matchingColumns": ["row_number"],
          "schema": [
            {
              "id": "H",
              "displayName": "H (ステータス)",
              "required": false,
              "defaultMatch": false,
              "display": true,
              "type": "string",
              "canBeUsedToMatch": false
            },
            {
              "id": "I",
              "displayName": "I (投稿ID)",
              "required": false,
              "defaultMatch": false,
