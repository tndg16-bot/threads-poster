      "notes": "H列を「エラー」に、J列にエラーメッセージを書き込む"
    },
    {
      "parameters": {
        "jsCode": "// Prepare Discord error notification\nconst items = $input.all();\nconst now = new Date();\nconst jstOffset = 9 * 60 * 60 * 1000;\nconst jstDate = new Date(now.getTime() + jstOffset);\nconst todayStr = jstDate.toISOString().split('T')[0];\n\nconst errorSummaries = items.map((item, i) => {\n  const text = item.json._fullText || '(不明)';\n  const err = item.json._errorMessage || 'Unknown';\n  return `${i + 1}. ${text}...\\n   ❌ ${err}`;\n}).join('\\n\\n');\n\nconst message = [\n  `🚨 **Threads投稿エラーレポート** (${todayStr})`,\n  ``,\n  `❌ エラー: ${items.length}件`,\n  ``,\n  errorSummaries,\n  ``,\n  `スプレッドシートを確認してください。`,\n  `---`,\n  `自動投稿 by n8n`\n].join('\\n');\n\nreturn [{ json: { content: message } }];"
      },
