      "id": "update-sheets-success",
      "name": "Google Sheets - 投稿済み更新",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [3840, 200],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "PLACEHOLDER_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets OAuth2"
        }
      },
      "notes": "H列を「投稿済み」に、I列に投稿IDを書き込む"
    },
    {
      "parameters": {
        "jsCode": "// Collect all successful posts for Discord summary\nconst items = $input.all();\nconst now = new Date();\nconst jstOffset = 9 * 60 * 60 * 1000;\nconst jstDate = new Date(now.getTime() + jstOffset);\nconst todayStr = jstDate.toISOString().split('T')[0];\n\nconst successCount = items.length;\nconst postSummaries = items.map((item, i) => {\n  const text = (item.json._fullText || '').substring(0, 50);\n  const category = item.json._category || '未分類';\n  const id = item.json._publishedId || 'N/A';\n  return `${i + 1}. [${category}] ${text}... (ID: ${id})`;\n}).join('\\n');\n\nconst message = [\n  `📬 **Threads投稿完了レポート** (${todayStr})`,\n  ``,\n  `✅ 投稿成功: ${successCount}件`,\n  ``,\n  postSummaries,\n  ``,\n  `---`,\n  `自動投稿 by n8n`\n].join('\\n');\n\nreturn [{ json: { content: message } }];"
      },
      "id": "prepare-discord-success",
      "name": "Discord通知準備 (成功)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4080, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "PLACEHOLDER_DISCORD_WEBHOOK_URL",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "content",
              "value": "={{ $json.content }}"
            }
          ]
        },
        "options": {}
      },
      "id": "discord-notify-success",
      "name": "Discord通知 - 成功",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [4320, 200]
    },
    {
      "parameters": {
        "jsCode": "// Error handler: capture error details and prepare for Sheet update + Discord notification\nconst item = $input.item;\nconst errorMessage = item.json.error?.message || item.json.error || 'Unknown error';\nconst errorCode = item.json.error?.code || item.json.statusCode || 'N/A';\n\nconst now = new Date();\nconst jstOffset = 9 * 60 * 60 * 1000;\nconst jstDate = new Date(now.getTime() + jstOffset);\nconst timestamp = jstDate.toISOString().replace('T', ' ').substring(0, 19);\n\nreturn {\n  json: {\n    _status: 'エラー',\n    _errorMessage: `[${timestamp}] Error ${errorCode}: ${errorMessage}`,\n    _rowNumber: item.json._rowNumber || 0,\n    _fullText: (item.json._fullText || item.json['投稿文'] || item.json['C'] || '').substring(0, 50),\n    _category: item.json['カテゴリ'] || item.json['D'] || item.json._category || ''\n  }\n};"
      },
      "id": "error-handler",
      "name": "エラーハンドリング",
      "type": "n8n-nodes-base.code",
