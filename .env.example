# Threads API Configuration
THREADS_APP_ID=your_app_id_here
THREADS_APP_SECRET=your_app_secret_here
THREADS_ACCESS_TOKEN=your_access_token_here

# Optional
THREADS_API_VERSION=v1.0
THREADS_DRY_RUN=false
THREADS_LOG_LEVEL=info

# Portfolio Site
PORTFOLIO_CONTENT_PATH=../portfolio-site/content/blog
PORTFOLIO_BASE_URL=https://takahiro-motoyama.vercel.app

# Discord (optional)
DISCORD_CHANNEL_ID=your_channel_id_here

# Token Store
TOKEN_STORE_PATH=./token-store.json

# AI Generation (optional)
AI_PROVIDER=anthropic          # anthropic or openai
AI_API_KEY=your_ai_api_key_here
AI_MODEL=                      # Leave empty for default (claude-haiku-4-5 / gpt-4o-mini)
